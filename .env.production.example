# ============================================================
#  Plantilla .env.production — Constancias AMDC (FASE 12)
#
#  Copiar a `.env.production` en el servidor y rellenar los
#  valores marcados ___GENERAR___ con:
#    openssl rand -base64 32
#  Cada secreto debe ser ÚNICO (no reusar el mismo string).
# ============================================================

# === Postgres en Docker dedicado (127.0.0.1:5438) ===
# Estos POSTGRES_* los lee `scripts/deploy.sh` para crear el
# contenedor. La app misma se conecta vía DATABASE_URL.
POSTGRES_USER=secretaria_prod
POSTGRES_PASSWORD=___GENERAR___
POSTGRES_DB=secretaria_prod

# La app corre con PM2 en el HOST; el contenedor Postgres expone
# 5438 en 127.0.0.1. Usar la misma password que POSTGRES_PASSWORD.
DATABASE_URL=postgresql://secretaria_prod:___MISMO_PASSWORD___@localhost:5438/secretaria_prod

# === Auth.js (detrás del reverse proxy AMDC) ===
# OBLIGATORIO: la app corre HTTP en :3010 y el proxy termina TLS.
# Sin AUTH_TRUST_HOST=true la cookie de sesión no se setea como
# Secure y el login no persiste (rebote a /login tras submit).
AUTH_SECRET=___GENERAR___
AUTH_TRUST_HOST=true
AUTH_URL=https://secretaria.amdc.hn
APP_URL=https://secretaria.amdc.hn

# === Verificación pública (HMAC de QR + tokens de verificación) ===
VERIFICATION_HMAC_SECRET=___GENERAR___

# === Márgenes PDF (pulgadas; calibrar contra papel membretado real) ===
PDF_TOP_MARGIN_INCHES=2.6
PDF_BOTTOM_MARGIN_INCHES=1.4
PDF_LEFT_MARGIN_INCHES=1.1
PDF_RIGHT_MARGIN_INCHES=0.9

# === Backup ===
# Retención de backups (días). El script borra los más viejos.
BACKUP_RETENTION_DAYS=30

# === Seed inicial (solo se aplica con `bash scripts/deploy.sh --first-deploy`) ===
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@amdc.hn
SEED_ADMIN_PASSWORD=___TEMPORAL_FUERTE___

# El NODE_ENV lo fija PM2/Next; no lo definas acá.
