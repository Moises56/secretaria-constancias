# ─────────────────────────────────────────────────────────────────────────────
# constancias-amdc — variables de entorno
# Copia este archivo a `.env` y completa los valores. NUNCA commitear `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# URL pública de la app (sin slash final). Usada para construir el link del QR.
APP_URL=http://localhost:3000

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Para desarrollo local con Docker (ver docker-compose.yml): host=localhost,
# puerto=5432, usuario y db según POSTGRES_USER / POSTGRES_DB del compose.
DATABASE_URL=postgresql://constancias:constancias@localhost:5432/constancias?schema=public

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Genera con:  openssl rand -base64 32
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
# URL canónica que NextAuth usa para construir callbacks. En prod = APP_URL.
AUTH_URL=http://localhost:3000

# ── Verificación pública de constancias ─────────────────────────────────────
# Genera con:  openssl rand -base64 32. Firma los tokens HMAC del QR.
VERIFICATION_HMAC_SECRET=replace-me-with-openssl-rand-base64-32

# ── Calibración de márgenes del PDF (papel membretado) ──────────────────────
# Valores en pulgadas. Ajustar tras prueba de impresión sobre membrete físico.
PDF_TOP_MARGIN_INCHES=2.6
PDF_BOTTOM_MARGIN_INCHES=1.4
PDF_LEFT_MARGIN_INCHES=1.1
PDF_RIGHT_MARGIN_INCHES=0.9

# ── Seed del admin inicial (usado por prisma/seed.ts) ───────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@amdc.gob.hn
SEED_ADMIN_PASSWORD=ChangeMe!Once12345
